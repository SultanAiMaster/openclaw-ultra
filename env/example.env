# OpenClaw Ultra - Environment Configuration
# Copy this to .env and fill in your values

# ===================
# REQUIRED CONFIG
# ===================

# Get your Groq API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Get your Telegram Bot Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (for admin features)
ADMIN_USER_ID=your_telegram_user_id_here

# ===================
# OPTIONAL CONFIG
# ===================

# Server port (default: 3000)
PORT=3000

# Memory type: 'local' (JSON file) or 'redis'
MEMORY_TYPE=local

# Redis URL (if using memory_type=redis)
REDIS_URL=redis://localhost:6379

# AI Model (Groq models)
# Options: mixtral-8x7b-32768, llama-3.3-70b-versatile, etc.
AI_MODEL=mixtral-8x7b-32768

# Response settings
MAX_TOKENS=2048
TEMPERATURE=0.7

# Security
SESSION_SECRET=change_this_to_random_string
